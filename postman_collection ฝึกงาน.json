            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"69f16917d2ddca6eb3e023c4\",\n  \"rating\": 5,\n  \"comment\": \"สินค้าดีมากครับ ส่งไวมาก\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/reviews", "host": ["{{baseUrl}}"], "path": ["reviews"] }
          },
          "response": [{ "name": "Review Created", "status": "Created", "code": 201, "body": "{\n  \"message\": \"Review submitted\",\n  \"review\": {\n    \"_id\": \"64rev...\",\n    \"productId\": \"69f16917d2ddca6eb3e023c4\",\n    \"rating\": 5,\n    \"comment\": \"สินค้าดีมากครับ ส่งไวมาก\"\n  }\n}" }]
        }
      ]
    }
  ]
}
